-- Funções
function TP(pos)
    local char = LP.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
        return true
    end
    return false
end

function FirePrompt(nome)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Name == nome and obj.Enabled then
            fireproximityprompt(obj)
            return true
        end
    end
    return false
end

function GetPromptPos(nome)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Name == nome and obj.Enabled then
            local part = obj.Parent
            if part and part:IsA("BasePart") then
                return part.Position
            end
        end
    end
    return nil
end

function GetCodigo()
    local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
    if not CodeIfuud then return nil end
    
    local Dialogo = CodeIfuud:FindFirstChild("DialogoFrame")
    if Dialogo and Dialogo.Visible then
        local Assunto = Dialogo:FindFirstChild("Assunto")
        if Assunto then
            return string.match(Assunto.Text, "(%d%d%d%d)")
        end
    end
    return nil
end

function InserirCodigo(codigo)
    if not codigo or #codigo ~= 4 then return false end
    
    local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
    if not CodeIfuud then return false end
    
    local Campo = nil
    for _, child in ipairs(CodeIfuud:GetDescendants()) do
        if child:IsA("TextBox") and child.Name == "CodigoTxt" then
            Campo = child
            break
        end
    end
    if not Campo then return false end
    
    Campo:CaptureFocus()
    task.wait(0.1)
    Campo.Text = ""
    task.wait(0.05)
    Campo.Text = codigo
    task.wait(0.1)
    
    for _, child in ipairs(CodeIfuud:GetDescendants()) do
        if child:IsA("TextButton") and child.Name == "Confirmar" then
            local pos = child.AbsolutePosition
            local size = child.AbsoluteSize
            VirtualInputManager:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, false, game, 0)
            return true
        end
    end
    return false
end

-- MONITORAMENTO
function Iniciar()
    EntregasCount = 0
    Ativo = true
    Btn.Text = "⏹ PARAR FARM"
    Btn.BackgroundColor3 = Color3.fromRGB(180, 20, 20)
    
    local fase = "parado"
    local ultimaAcao = 0
    
    Heartbeat = RunService.Heartbeat:Connect(function()
        if not Ativo then return end
        
        local agora = tick()
        
        -- Só age a cada 0.3 segundos pra não sobrecarregar
        if agora - ultimaAcao < 0.3 then return end
        ultimaAcao = agora
        
        -- DETECTOU PROMPT DE PEGAR PEDIDO
        if fase == "parado" or fase == "monitorando" then
            local pos = GetPromptPos("PegarPedido")
            if pos then
                fase = "coleta"
                Btn.Text = "📦 Coletando..."
                
                -- Teleporta pro prompt
                TP(pos + Vector3.new(0, 3, 0))
                task.wait(0.2)
                
                -- Dispara fireproximityprompt
                FirePrompt("PegarPedido")
                task.wait(1)
                fase = "coletou"
                Btn.Text = "📥 Pegou pedido"
                print("[Farm] Pedido coletado!")
            end
        end
        
        -- DETECTOU PROMPT DE ENTREGAR
        if fase == "coletou" or fase == "coleta" then
            local pos = GetPromptPos("Entregar")
            if pos then
                fase = "entrega"
                Btn.Text = "📍 Entregando..."
                
                -- Teleporta pro prompt
                TP(pos + Vector3.new(0, 3, 0))
                task.wait(0.2)
                
                -- Tenta pegar código se diálogo estiver aberto
                local codigo = GetCodigo()
                if codigo then
                    Btn.Text = "🔑 Código: " .. codigo
                    InserirCodigo(codigo)
                    task.wait(0.5)
                end
                
                -- Dispara fireproximityprompt
                FirePrompt("Entregar")
                task.wait(2)
                
                EntregasCount = EntregasCount + 1
                print("[Farm] ✅ Entrega " .. EntregasCount .. " concluída!")
                
                fase = "parado"
                Btn.Text = "🍔 AUTO FARM (" .. EntregasCount .. ")"
            end
        end
        
        -- VERIFICA DIÁLOGO DE CÓDIGO A QUALQUER MOMENTO
        if fase ~= "codigo" and fase ~= "entrega" then
            local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
            if CodeIfuud then
                local Dialogo = CodeIfuud:FindFirstChild("DialogoFrame")
                if Dialogo and Dialogo.Visible then
                    local codigo = GetCodigo()
                    if codigo then
                        fase = "codigo"
                        Btn.Text = "🔑 Código: " .. codigo
                        InserirCodigo(codigo)
                        task.wait(0.5)
                        
                        -- Se tiver prompt de entrega, já dispara
                        local pos = GetPromptPos("Entregar")
                        if pos then
                            TP(pos + Vector3.new(0, 3, 0))
                            task.wait(0.2)
                            FirePrompt("Entregar")
                            task.wait(2)
                            EntregasCount = EntregasCount + 1
                            print("[Farm] ✅ Entrega " .. EntregasCount .. " concluída!")
                            fase = "parado"
                            Btn.Text = "🍔 AUTO FARM (" .. EntregasCount .. ")"
                        else
                            fase = "coletou"
                            Btn.Text = "📥 Código inserido"
                        end
                    end
                end
            end
        end
        
        -- Se fase ficou parada por muito tempo, volta a monitorar
        if fase == "coletou" or fase == "codigo" then
            -- Só volta a monitorar se não tiver prompt de entrega
            if not GetPromptPos("Entregar") then
                -- Aguarda 2 segundos antes de considerar que finalizou
                task.wait(2)
                fase = "parado"
                Btn.Text = "🍔 AUTO FARM (" .. EntregasCount .. ")"
            end
        end
    end)
end

function Parar()
    Ativo = false
    if Heartbeat then
        Heartbeat:Disconnect()
        Heartbeat = nil
    end
    Btn.Text = "🍔 AUTO FARM"
    Btn.BackgroundColor3 = Color3.fromRGB(232, 29, 43)
    print("[Farm] Desativado. Total de entregas: " .. EntregasCount)
end

-- Clique no botão
Btn.MouseButton1Click:Connect(function()
    if Ativo then
        Parar()
    else
        Iniciar()
    end
end)

