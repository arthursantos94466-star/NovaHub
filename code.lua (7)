local function UpdateHighlights()
    for _, hl in pairs(activeHighlights) do hl:Destroy() end
    table.clear(activeHighlights)
    if not Settings.Highlight then return end
    
    local folder = Workspace:FindFirstChild("NPCs")
    if not folder then return end
    
    for _, npc in pairs(folder:GetChildren()) do
        if npc:IsA("Model") then
            local hum = npc:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(255, 0, 80)
                hl.FillTransparency = 0.35
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.OutlineTransparency = 0.1
                hl.Adornee = npc
                hl.Parent = npc
                activeHighlights[npc] = hl
                
                task.spawn(function()
                    local t = 0
                    while activeHighlights[npc] and Settings.Highlight do
                        t = t + 0.05
                        hl.FillTransparency = 0.25 + math.sin(t * 3) * 0.15
                        task.wait(0.05)
                    end
                end)
            end
        end
    end
end

