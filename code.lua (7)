-- ==========================================
-- FUNÇÃO: WALL CHECK (RAYCAST)
-- ==========================================

local function IsTargetVisible(targetPart)
    if not targetPart then return false end
    
    local origin = Camera.CFrame.Position
    local destination = targetPart.Position
    local direction = (destination - origin).Unit
    local distance = (destination - origin).Magnitude
    
    -- Raycast
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
    params.IgnoreWater = true
    
    local result = Workspace:Raycast(origin, direction * distance, params)
    
    -- Se não acertou nada, está visível
    if not result then return true end
    
    -- Se acertou algo, verifica se é o próprio alvo
    local hitPart = result.Instance
    if hitPart and (hitPart:IsDescendantOf(targetPart.Parent) or hitPart == targetPart) then
        return true
    end
    
    return false
end

-- ==========================================
-- FUNÇÃO: ENCONTRAR ALVO (com wall check)
-- ==========================================

local function GetTarget()
    local bestTarget = nil
    local bestDist = FOV_RADIUS
    
    -- Salva a posição atual do mouse/toque para não variar sozinha
    local mousePos = UserInputService:GetMouseLocation()
    
    -- Procura NPCs
    local folder = Workspace:FindFirstChild("NPCs")
    if folder then
        for _, npc in pairs(folder:GetChildren()) do
            if npc:IsA("Model") then
                local head = npc:FindFirstChild("Head")
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if head and hum and hum.Health > 0 then
                    -- Wall check
                    if not IsTargetVisible(head) then continue end
                    
                    local sp, on = Camera:WorldToViewportPoint(head.Position)
                    if on then
                        local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestTarget = head
                        end
                    end
                end
            end
        end
    end
    
    -- Procura jogadores
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char then
                local head = char:FindFirstChild("Head")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if head and hum and hum.Health > 0 then
                    -- Wall check
                    if not IsTargetVisible(head) then continue end
                    
                    local sp, on = Camera:WorldToViewportPoint(head.Position)
                    if on then
                        local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestTarget = head
                        end
                    end
                end
            end
        end
    end
    
    return bestTarget
end

-- ==========================================
-- FUNÇÃO: SISTEMA DE MIRA INTELIGENTE
-- ==========================================

local aimConnection = nil
local currentTarget = nil         -- Alvo atual travado
local targetLockTime = 0          -- Timestamp de quando travou
local MIN_LOCK_TIME = 1.5          -- Tempo mínimo com mesmo alvo
local TARGET_RESET_TIME = 0.5     -- Tempo sem ver o alvo para destravar

-- Verifica se o alvo ainda está vivo e visível
local function IsTargetValid(target)
    if not target or not target.Parent then return false end
    local hum = target.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not IsTargetVisible(target) then return false end
    return true
end

local function SetupAim()
    if aimConnection then aimConnection:Disconnect() end
    
    aimConnection = RunService.RenderStepped:Connect(function()
        if not Settings.Aimbot and not Settings.AimAssist then
            currentTarget = nil
            return
        end
        
        -- Verifica se o alvo atual ainda é válido
        if currentTarget and IsTargetValid(currentTarget) then
            -- Tudo ok, continua com o mesmo alvo
        else
            -- Precisa encontrar um novo alvo
            currentTarget = GetTarget()
            if currentTarget then
                targetLockTime = tick()
            end
        end
        
        if not currentTarget then return end
        
        -- Verifica se passou tempo mínimo de lock (evita troca ao clicar)
        if tick() - targetLockTime < 0.1 then
            -- Acabou de travar, deixa estabilizar
            return
        end
        
        local currentCF = Camera.CFrame
        local targetPos = currentTarget.Position
        
        -- AIMBOT
        if Settings.Aimbot then
            local lookAt = CFrame.lookAt(currentCF.Position, targetPos)
            local smooth = math.clamp(1 - AIMBOT_SMOOTH, 0.05, 0.7)
            Camera.CFrame = currentCF:Lerp(lookAt, smooth)
        end
        
        -- AIM ASSIST (só se aimbot estiver desligado)
        if Settings.AimAssist and not Settings.Aimbot then
            local lookAt = CFrame.lookAt(currentCF.Position, targetPos)
            -- Força extremamente fraca
            Camera.CFrame = currentCF:Lerp(lookAt, ASSIST_STRENGTH)
        end
    end)
end

-- ==========================================
-- WATCHDOG
-- ==========================================

task.spawn(function()
    SetupAim()
    
    while task.wait(0.1) do
        -- Highlight
        if Settings.Highlight then
            UpdateHighlights()
            local f = Workspace:FindFirstChild("NPCs")
            if f and not npcConn then
                npcConn = f.ChildAdded:Connect(OnNPCAdded)
            end
        else
            for _, hl in pairs(activeHighlights) do hl:Destroy() end
            table.clear(activeHighlights)
            if npcConn then npcConn:Disconnect(); npcConn = nil end
        end
        
        -- Mira
        if Settings.Aimbot or Settings.AimAssist then
            if not aimConnection then SetupAim() end
        end
    end
end)

