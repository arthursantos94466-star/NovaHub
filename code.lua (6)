-- FUNÇÃO: CRIAR TOGGLE MOBILE (grande)
-- ==========================================
local function CreateToggle(parent, text, icon, defaultState, color, callback)
    local state = defaultState or false
    
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
    ToggleFrame.BorderSizePixel = 0
    ToggleFrame.Size = UDim2.new(0, 145, 0, 48)
    ToggleFrame.Parent = parent
    
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 12)
    ToggleCorner.Parent = ToggleFrame
    
    -- Ícone
    local IconLabel = Instance.new("TextLabel")
    IconLabel.Text = icon or ""
    IconLabel.Size = UDim2.new(0, 34, 1, 0)
    IconLabel.Position = UDim2.new(0, 8, 0, 0)
    IconLabel.BackgroundTransparency = 1
    IconLabel.TextColor3 = Color3.fromRGB(180, 180, 220)
    IconLabel.Font = Enum.Font.GothamBold
    IconLabel.TextSize = 20
    IconLabel.Parent = ToggleFrame
    
    -- Texto
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Text = text
    TextLabel.Size = UDim2.new(1, -88, 1, 0)
    TextLabel.Position = UDim2.new(0, 44, 0, 0)
    TextLabel.BackgroundTransparency = 1
    TextLabel.TextColor3 = Color3.fromRGB(170, 170, 200)
    TextLabel.Font = Enum.Font.Gotham
    TextLabel.TextSize = 14
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.Parent = ToggleFrame
    
    -- Switch (track)
    local SwitchTrack = Instance.new("Frame")
    SwitchTrack.Size = UDim2.new(0, 40, 0, 24)
    SwitchTrack.Position = UDim2.new(1, -48, 0.5, -12)
    SwitchTrack.BackgroundColor3 = Color3.fromRGB(65, 65, 85)
    SwitchTrack.BorderSizePixel = 0
    SwitchTrack.Parent = ToggleFrame
    
    local TrackCorner = Instance.new("UICorner")
    TrackCorner.CornerRadius = UDim.new(0, 12)
    TrackCorner.Parent = SwitchTrack
    
    -- Switch (thumb)
    local SwitchThumb = Instance.new("Frame")
    SwitchThumb.Size = UDim2.new(0, 20, 0, 20)
    SwitchThumb.Position = UDim2.new(0, 2, 0.5, -10)
    SwitchThumb.BackgroundColor3 = Color3.fromRGB(200, 200, 220)
    SwitchThumb.BorderSizePixel = 0
    SwitchThumb.Parent = SwitchTrack
    
    local ThumbCorner = Instance.new("UICorner")
    ThumbCorner.CornerRadius = UDim.new(0, 10)
    ThumbCorner.Parent = SwitchThumb
    
    -- Feedback visual
    local function UpdateVisual()
        if state then
            IconLabel.TextColor3 = color or Color3.fromRGB(0, 255, 120)
            TextLabel.TextColor3 = color or Color3.fromRGB(0, 255, 120)
            TweenService:Create(SwitchTrack, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundColor3 = color or Color3.fromRGB(0, 220, 100)
            }):Play()
            TweenService:Create(SwitchThumb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(0, 18, 0.5, -10)
            }):Play()
        else
            IconLabel.TextColor3 = Color3.fromRGB(180, 180, 220)
            TextLabel.TextColor3 = Color3.fromRGB(170, 170, 200)
            TweenService:Create(SwitchTrack, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundColor3 = Color3.fromRGB(65, 65, 85)
            }):Play()
            TweenService:Create(SwitchThumb, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(0, 2, 0.5, -10)
            }):Play()
        end
    end
    
    -- Toque/clique
    ToggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            state = not state
            UpdateVisual()
            if callback then callback(state) end
        end
    end)
    
    UpdateVisual()
    return ToggleFrame
end

