-- ==========================================
-- FUNÇÃO: HIGHLIGHT (workspace.NPCs)
-- ==========================================

local function UpdateHighlights()
    -- Remove destaques antigos
    for _, hl in pairs(activeHighlights) do
        hl:Destroy()
    end
    table.clear(activeHighlights)
    
    if not highlightEnabled then return end
    
    local NPCsFolder = Workspace:FindFirstChild("NPCs")
    if not NPCsFolder then return end
    
    for _, npc in pairs(NPCsFolder:GetChildren()) do
        if npc:IsA("Model") then
            local humanoid = npc:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local hl = Instance.new("Highlight")
                hl.FillColor = Color3.fromRGB(255, 0, 80)
                hl.FillTransparency = 0.35
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.OutlineTransparency = 0.1
                hl.Adornee = npc
                hl.Parent = npc
                activeHighlights[npc] = hl
                
                -- Efeito pulsante
                task.spawn(function()
                    local t = 0
                    while activeHighlights[npc] and highlightEnabled do
                        t = t + 0.05
                        hl.FillTransparency = 0.25 + math.sin(t * 3) * 0.15
                        task.wait(0.05)
                    end
                end)
            end
        end
    end
end

local npcConnection = nil

local function OnNPCAdded(child)
    if not highlightEnabled then return end
    task.wait(0.5)
    
    if child:IsA("Model") then
        local humanoid = child:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local hl = Instance.new("Highlight")
            hl.FillColor = Color3.fromRGB(255, 0, 80)
            hl.FillTransparency = 0.35
            hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            hl.OutlineTransparency = 0.1
            hl.Adornee = child
            hl.Parent = child
            activeHighlights[child] = hl
        end
    end
end

local function ToggleHighlightSystem(enable)
    if enable then
        UpdateHighlights()
        local npcFolder = Workspace:FindFirstChild("NPCs")
        if npcFolder then
            npcConnection = npcFolder.ChildAdded:Connect(OnNPCAdded)
        end
    else
        for _, hl in pairs(activeHighlights) do
            hl:Destroy()
        end
        table.clear(activeHighlights)
        
        if npcConnection then
            npcConnection:Disconnect()
            npcConnection = nil
        end
    end
end

-- ==========================================
-- FUNÇÃO: AIMBOT + AIM ASSIST (MOBILE)
-- ==========================================

local function GetBestTarget()
    local bestTarget = nil
    local bestDist = aimFOV
    
    -- NPCs
    local NPCsFolder = Workspace:FindFirstChild("NPCs")
    if NPCsFolder then
        for _, npc in pairs(NPCsFolder:GetChildren()) do
            if npc:IsA("Model") then
                local head = npc:FindFirstChild("Head")
                local humanoid = npc:FindFirstChildOfClass("Humanoid")
                if head and humanoid and humanoid.Health > 0 then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local mousePos = UserInputService:GetMouseLocation()
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if dist < bestDist and dist > 0 then
                            bestDist = dist
                            bestTarget = head
                        end
                    end
                end
            end
        end
    end
    
    -- Jogadores
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character
            if char then
                local head = char:FindFirstChild("Head")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if head and humanoid and humanoid.Health > 0 then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local mousePos = UserInputService:GetMouseLocation()
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if dist < bestDist and dist > 0 then
                            bestDist = dist
                            bestTarget = head
                        end
                    end
                end
            end
        end
    end
    
    return bestTarget
end

-- Sistema de mira que RODA NO CELULAR
local aimConnection = nil

local function SetupAimSystem()
    if aimConnection then
        aimConnection:Disconnect()
    end
    
    aimConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled and not aimAssistEnabled then return end
        
        local target = GetBestTarget()
        if not target then return end
        
        local currentCF = Camera.CFrame
        local targetPos = target.Position
        
        -- AIMBOT: mira na cabeça com suavidade
        if aimbotEnabled then
            local lookAt = CFrame.lookAt(currentCF.Position, targetPos)
            local smooth = math.clamp(1 - aimbotSmoothness, 0.05, 0.7)
            Camera.CFrame = currentCF:Lerp(lookAt, smooth)
        end
        
        -- AIM ASSIST: NÃO GRUDA, só auxilia leve
        if aimAssistEnabled and not aimbotEnabled then
            local lookAt = CFrame.lookAt(currentCF.Position, targetPos)
            -- Força extremamente fraca: 0.05 a 0.15 (não gruda!)
            Camera.CFrame = currentCF:Lerp(lookAt, aimAssistStrength)
        end
    end)
end

-- ==========================================
-- WATCHDOG: GERENCIA SISTEMAS
-- ==========================================
task.spawn(function()
    SetupAimSystem()
    
    while task.wait(0.15) do
        -- Highlight
        ToggleHighlightSystem(highlightEnabled)
        
        -- Aimbot/AimAssist
        if aimbotEnabled or aimAssistEnabled then
            if not aimConnection then SetupAimSystem() end
        end
    end
end)

