-- Pegar posi√ß√£o do prompt
function GetPromptPos(nome)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Name == nome and obj.Enabled then
            local part = obj.Parent
            if part and part:IsA("BasePart") then
                return part.Position
            end
        end
    end
    return nil
end

-- Pegar c√≥digo do di√°logo
function GetCodigo()
    local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
    if not CodeIfuud then return nil end
    
    local Dialogo = CodeIfuud:FindFirstChild("DialogoFrame")
    if not Dialogo or not Dialogo.Visible then return nil end
    
    local Assunto = Dialogo:FindFirstChild("Assunto")
    if not Assunto then return nil end
    
    return string.match(Assunto.Text, "(%d%d%d%d)")
end

-- Inserir c√≥digo
function InserirCodigo(codigo)
    if not codigo then return false end
    
    local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
    if not CodeIfuud then return false end
    
    local Campo = nil
    for _, child in ipairs(CodeIfuud:GetDescendants()) do
        if child:IsA("TextBox") and child.Name == "CodigoTxt" then
            Campo = child
            break
        end
    end
    
    if not Campo then return false end
    
    Campo:CaptureFocus()
    task.wait(0.1)
    Campo.Text = ""
    task.wait(0.05)
    Campo.Text = codigo
    task.wait(0.1)
    
    -- Clica em Confirmar
    for _, child in ipairs(CodeIfuud:GetDescendants()) do
        if child:IsA("TextButton") and child.Name == "Confirmar" and child.Interactable ~= false then
            local pos = child.AbsolutePosition
            local size = child.AbsoluteSize
            VirtualInputManager:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(pos.X + size.X/2, pos.Y + size.Y/2, 0, false, game, 0)
            return true
        end
    end
    
    return false
end

-- Aguardar prompt aparecer
function EsperarPrompt(nome, maxTempo)
    maxTempo = maxTempo or 8
    local tempo = 0
    
    while tempo < maxTempo and Estado.Ativo do
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Name == nome and obj.Enabled then
                return true
            end
        end
        task.wait(0.3)
        tempo = tempo + 0.3
    end
    return false
end

-- ============================================================
-- LOOP PRINCIPAL (S√ď O QUE VC PEDIU)
-- ============================================================

function Loop()
    while Estado.Ativo do
        -- 1. ESPERA O PROMPT PEGARPEDIDO APARECER
        Estado.Fase = "Coleta"
        AtualizarUI()
        
        if not EsperarPrompt("PegarPedido", 15) then break end
        
        -- 2. TELEPORTA PRO LOCAL DE PEGAR
        local pos = GetPromptPos("PegarPedido")
        if pos then
            TP(pos + Vector3.new(0, 3, 0))
            task.wait(0.3)
        end
        
        -- 3. DISPARA FIREPROXIMITYPROMPT
        Estado.Fase = "Pegar"
        AtualizarUI()
        FirePrompt("PegarPedido")
        task.wait(1.5)
        
        -- 4. ESPERA PROMPT DE ENTREGAR
        Estado.Fase = "Entrega"
        AtualizarUI()
        
        if not EsperarPrompt("Entregar", 10) then break end
        
        -- 5. TELEPORTA PRO LOCAL DE ENTREGA
        pos = GetPromptPos("Entregar")
        if pos then
            TP(pos + Vector3.new(0, 3, 0))
            task.wait(0.3)
        end
        
        -- 6. ESPERA DI√ĀLOGO E INSERE C√ďDIGO
        Estado.Fase = "Codigo"
        AtualizarUI()
        
        local tempo = 0
        while tempo < 5 and Estado.Ativo do
            local CodeIfuud = LP.PlayerGui:FindFirstChild("CodeIfuud")
            if CodeIfuud then
                local Dialogo = CodeIfuud:FindFirstChild("DialogoFrame")
                if Dialogo and Dialogo.Visible then
                    break
                end
            end
            task.wait(0.2)
            tempo = tempo + 0.2
        end
        
        -- Pega o c√≥digo e insere
        local codigo = GetCodigo()
        if codigo then
            print("[Farm] C√≥digo: " .. codigo)
            InserirCodigo(codigo)
            task.wait(1)
        end
        
        -- 7. DISPARA PROMPT DE ENTREGAR
        FirePrompt("Entregar")
        task.wait(2)
        
        -- 8. FINALIZOU
        Estado.Entregas = Estado.Entregas + 1
        AtualizarUI()
        print("[Farm] ‚úÖ Entrega " .. Estado.Entregas .. " conclu√≠da!")
        
        task.wait(0.5)
    end
    
    Estado.Fase = "Parado"
    AtualizarUI()
end

