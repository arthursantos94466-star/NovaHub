AutoFarmButton.MouseButton1Click:Connect(function()
	Farming = not Farming

	if Farming then
		AutoFarmButton.Text = "AUTO FARM: ON"
		AutoFarmButton.BackgroundColor3 = Color3.fromRGB(50, 200, 80)

		task.spawn(function()
			while Farming do
				for _, crate in ipairs(workspace["Destroyable Crates"]:GetChildren()) do
					if not Farming then
						break
					end

					local center = crate:FindFirstChild("CenterPiece", true)

					if center and center:IsA("BasePart") then
						HRP.CFrame = center.CFrame + Vector3.new(0, 3, 0)

						local start = tick()

						while tick() - start < 1.83 and Farming and crate.Parent do
							RS.AlienAbilities.AbilityInputBindable:Fire(Tool)
							task.wait(0.1)
						end

task.wait(0.5)

					end
				end

				task.wait()
			end
		end)

	else
		AutoFarmButton.Text = "AUTO FARM: OFF"
		AutoFarmButton.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
	end
end)

-- Arrastar GUI (mobile)
local UIS = game:GetService("UserInputService")
local dragging = false
local dragStart
local startPos

Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.Touch then
		local delta = input.Position - dragStart

		Frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
