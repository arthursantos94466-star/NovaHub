-- Função para checar a colisão no objeto correto ("Collision")
local function IsCrateValid(crateModel)
	if not crateModel or not crateModel.Parent then return false end
	
	-- Procura o objeto que gerencia a colisão dentro do modelo da caixa
	local collisionPart = crateModel:FindFirstChild("Collision", true)
	
	-- Se não achar a peça de colisão, assume que a caixa está quebrada ou inválida
	if not collisionPart or not collisionPart:IsA("BasePart") then 
		return false 
	end
	
	-- Retorna se a colisão ainda está ativa
	return collisionPart.CanCollide and collisionPart.CanTouch
end

