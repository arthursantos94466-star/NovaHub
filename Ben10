AutoFarmButton.MouseButton1Click:Connect(function()
	Farming = not Farming

	if Farming then
		AutoFarmButton.Text = "AUTO FARM: ON"
		AutoFarmButton.BackgroundColor3 = Color3.fromRGB(50, 200, 80)

		task.spawn(function()
			while Farming do
				-- Atualiza referências do personagem para evitar bugs de travamento
				Character = Player.Character or Player.CharacterAdded:Wait()
				HRP = Character:WaitForChild("HumanoidRootPart")
				Tool = Character:FindFirstChild("Player_Melee") or Player:WaitForChild("Backpack"):FindFirstChild("Player_Melee")

				local cratesFolder = workspace:FindFirstChild("Destroyable Crates")
				if cratesFolder then
					for _, crate in ipairs(cratesFolder:GetChildren()) do
						if not Farming then break end

						-- 1. Verifica se a colisão na parte "Collision" está ativa antes de ir
						if IsCrateValid(crate) then
							local center = crate:FindFirstChild("CenterPiece", true)

							-- 2. Se a colisão for válida e o CenterPiece existir, faz o teleporte
							if center and center:IsA("BasePart") then
								
								-- Equipar a ferramenta automaticamente se necessário
								if Tool and Tool.Parent == Player:FindFirstChild("Backpack") then
									Tool.Parent = Character
								end

								-- Teleporta para o CenterPiece
								HRP.CFrame = center.CFrame + Vector3.new(0, 3, 0)

								local start = tick()

								-- Loop de ataque na caixa
								while tick() - start < 1.83 and Farming and crate.Parent do
									-- 3. Se a parte "Collision" desativar o CanCollide no meio do ataque, sai do loop na hora
									if not IsCrateValid(crate) then
										break
									end

									RS.AlienAbilities.AbilityInputBindable:Fire(Tool)
									task.wait(0.1)
								end

								task.wait(0.1) -- Pausa mínima para estabilizar a transição física
							end
						end
					end
				end

				task.wait(0.2)
			end
		end)

	else
		AutoFarmButton.Text = "AUTO FARM: OFF"
		AutoFarmButton.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
	end
end)

-- Sistema de Arrastar GUI (Universal para Mobile & PC)
local dragging = false
local dragStart, startPos

Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
		local delta = input.Position - dragStart
		Frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)
