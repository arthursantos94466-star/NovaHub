-- HIGHLIGHT (ESP em NPCs)
local highlightConnections = {}

function ToggleHighlight(enable)
    if enable then
        -- Encontra NPCs (personagens que n√£o s√£o jogadores)
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                local highlight = Instance.new("Highlight")
                highlight.Name = "HackerAI_Highlight"
                highlight.Adornee = obj
                highlight.FillColor = Color3.fromRGB(255, 50, 50)
                highlight.OutlineColor = Color3.fromRGB(255, 200, 50)
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0.2
                highlight.Parent = obj
            end
        end
        
        -- Monitora novos NPCs
        local conn = Workspace.DescendantAdded:Connect(function(obj)
            task.wait(0.5)
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                if not obj:FindFirstChild("HackerAI_Highlight") then
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "HackerAI_Highlight"
                    highlight.Adornee = obj
                    highlight.FillColor = Color3.fromRGB(255, 50, 50)
                    highlight.OutlineColor = Color3.fromRGB(255, 200, 50)
                    highlight.FillTransparency = 0.5
                    highlight.OutlineTransparency = 0.2
                    highlight.Parent = obj
                end
            end
        end)
        table.insert(highlightConnections, conn)
    else
        -- Remove highlights
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name == "HackerAI_Highlight" then
                obj:Destroy()
            end
        end
        -- Remove conex√Ķes
        for _, conn in ipairs(highlightConnections) do
            conn:Disconnect()
        end
        highlightConnections = {}
    end
end

-- AIMBOT / AIM ASSIST
local aimConnection = nil

function ToggleAimbot(enable)
    if enable then
        if aimConnection then
            aimConnection:Disconnect()
        end
        
        aimConnection = RunService.RenderStepped:Connect(function()
            if not Settings.Aimbot and not Settings.AimAssist then return end
            
            local closestTarget = nil
            local closestDist = Settings.FOVRadius
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                
                local character = player.Character
                if not character or not character:FindFirstChild("HumanoidRootPart") then continue end
                if character.Humanoid.Health <= 0 then continue end
                
                local targetPart = character:FindFirstChild(Settings.TargetPart) or character:FindFirstChild("HumanoidRootPart")
                if not targetPart then continue end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if not onScreen then continue end
                
                local mousePos = UserInputService:GetMouseLocation()
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                
                if dist < closestDist then
                    closestDist = dist
                    closestTarget = targetPart
                end
            end
            
            if closestTarget then
                if Settings.Aimbot then
                    -- Aimbot puro: mira diretamente na cabe√ßa (com smoothness)
                    local targetPos = closestTarget.Position
                    local currentCF = Camera.CFrame
                    
                    local lookAtCF = CFrame.lookAt(currentCF.Position, targetPos)
                    local smoothedCF = currentCF:Lerp(lookAtCF, 1 - Settings.Smoothness)
                    
                    Camera.CFrame = smoothedCF
                elseif Settings.AimAssist then
                    -- Aim Assist: suaviza a mira, N√ÉO gruda
                    local targetPos = closestTarget.Position
                    local currentCF = Camera.CFrame
                    
                    -- Apenas suaviza levemente a rota√ß√£o (n√£o gruda)
                    local lookAtCF = CFrame.lookAt(currentCF.Position, targetPos)
                    local smoothedCF = currentCF:Lerp(lookAtCF, (1 - Settings.Smoothness) * 0.3)
                    
                    Camera.CFrame = smoothedCF
                end
            end
        end)
    else
        if aimConnection then
            aimConnection:Disconnect()
            aimConnection = nil
        end
    end
end

