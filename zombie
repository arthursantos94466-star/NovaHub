-- FUN√á√ÉO PARA CRIAR TOGGLE (BOT√ÉO LIGA/DESLISA)
-- ============================================================
function Library:CreateToggle(container, text, defaultValue, callback)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    ToggleFrame.BorderSizePixel = 0
    ToggleFrame.Size = UDim2.new(0, 130, 0, 36)
    ToggleFrame.Parent = container
    
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 8)
    ToggleCorner.Parent = ToggleFrame
    
    local ToggleLabel = Instance.new("TextLabel")
    ToggleLabel.Text = text
    ToggleLabel.Size = UDim2.new(1, -50, 1, 0)
    ToggleLabel.Position = UDim2.new(0, 10, 0, 0)
    ToggleLabel.BackgroundTransparency = 1
    ToggleLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
    ToggleLabel.Font = Enum.Font.Gotham
    ToggleLabel.TextSize = 13
    ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left
    ToggleLabel.Parent = ToggleFrame
    
    -- Circulo do toggle
    local ToggleIndicator = Instance.new("ImageLabel")
    ToggleIndicator.Name = "Indicator"
    ToggleIndicator.Size = UDim2.new(0, 30, 0, 20)
    ToggleIndicator.Position = UDim2.new(1, -38, 0.5, -10)
    ToggleIndicator.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
    ToggleIndicator.BackgroundTransparency = 0.5
    ToggleIndicator.BorderSizePixel = 0
    ToggleIndicator.Image = "rbxassetid://3570695787"
    ToggleIndicator.ImageColor3 = Color3.fromRGB(80, 80, 100)
    ToggleIndicator.ScaleType = Enum.ScaleType.Slice
    ToggleIndicator.SliceCenter = Rect.new(100, 100, 100, 100)
    ToggleIndicator.Parent = ToggleFrame
    
    local IndicatorCorner = Instance.new("UICorner")
    IndicatorCorner.CornerRadius = UDim.new(0, 10)
    IndicatorCorner.Parent = ToggleIndicator
    
    local ToggleCircle = Instance.new("Frame")
    ToggleCircle.Name = "Circle"
    ToggleCircle.Size = UDim2.new(0, 16, 0, 16)
    ToggleCircle.Position = UDim2.new(0, 2, 0.5, -8)
    ToggleCircle.BackgroundColor3 = Color3.fromRGB(200, 200, 210)
    ToggleCircle.BorderSizePixel = 0
    ToggleCircle.Parent = ToggleIndicator
    
    local CircleCorner = Instance.new("UICorner")
    CircleCorner.CornerRadius = UDim.new(0, 8)
    CircleCorner.Parent = ToggleCircle
    
    local enabled = defaultValue or false
    
    local function UpdateToggle()
        if enabled then
            ToggleIndicator.BackgroundColor3 = Color3.fromRGB(0, 180, 120)
            ToggleIndicator.BackgroundTransparency = 0
            ToggleIndicator.ImageColor3 = Color3.fromRGB(0, 180, 120)
            
            local goal = {Position = UDim2.new(0, 14, 0.5, -8)}
            local tween = TweenService:Create(ToggleCircle, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal)
            tween:Play()
            
            ToggleLabel.TextColor3 = Color3.fromRGB(0, 200, 140)
        else
            ToggleIndicator.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            ToggleIndicator.BackgroundTransparency = 0.5
            ToggleIndicator.ImageColor3 = Color3.fromRGB(80, 80, 100)
            
            local goal = {Position = UDim2.new(0, 2, 0.5, -8)}
            local tween = TweenService:Create(ToggleCircle, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal)
            tween:Play()
            
            ToggleLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
        end
    end
    
    local function Toggle()
        enabled = not enabled
        UpdateToggle()
        if callback then
            callback(enabled)
        end
    end
    
    ToggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            Toggle()
        end
    end)
    
    -- Efeito hover
    ToggleFrame.MouseEnter:Connect(function()
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
    end)
    ToggleFrame.MouseLeave:Connect(function()
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    end)
    
    UpdateToggle()
    return ToggleFrame, function() return enabled end, Toggle
end

